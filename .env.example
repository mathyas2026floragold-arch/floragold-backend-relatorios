PORT=3000

# false = modo real/verídico. true = apenas teste de validação; NÃO gera relatório.
DEMO_MODE=false

# URL do sistema de origem
SISTEMA_URL=https://floragold.acessocloud.com/index.php

# No Render deixe true. Localmente, pode colocar false para ver o navegador abrindo.
HEADLESS=true

# Permita o domínio do Netlify em produção, ou * durante teste.
CORS_ORIGIN=*

# Pasta de saída dos relatórios
REPORT_DIR=./relatorios

# Quantidade por página no sistema original
LINHAS_POR_PAGINA=3000

# Segurança do discador/0800
AUTO_PAUSE=true
WAIT_FOR_CALL_FINISH=false
PAUSE_TEXTS=ligacao 0800,ligação 0800,retirar pausa
ACTIVE_CALL_TEXTS=em chamada,chamada ativa,atendendo,discando,ligacao ativa,ligação ativa,atendimento em andamento
AVAILABLE_TEXTS=disponivel,disponível,online,livre

# Se a tela de login tiver selects obrigatórios, configure os valores aqui.
# Exemplo: LOGIN_SELECT_1_VALUE=1002
LOGIN_SELECT_1_VALUE=
LOGIN_SELECT_2_VALUE=

# Pausa FloraGold
# O sistema considera pausa segura quando o status aparece como "1002 - Ligação 0800".
# Se o usuário estiver "1002 - Disponível", o robô seleciona Ligação 0800 e clica em Iniciar pausa.
PAUSE_REASON_LABEL=Ligação 0800
PAUSE_REASON_SELECTOR=
REMOVE_PAUSE_BUTTON_SELECTOR=

# Seletores opcionais do sistema real. Preencha quando descobrir o HTML.
LOGIN_USER_SELECTOR=
LOGIN_PASS_SELECTOR=
LOGIN_BUTTON_SELECTOR=
PAUSE_BUTTON_SELECTOR=
REPORT_MENU_SELECTOR=
CALLS_MENU_SELECTOR=
ENTRANTE_MENU_SELECTOR=
FILTERS_BUTTON_SELECTOR=
FILTER_DATE_SELECTOR=
FILTER_START_DATE_SELECTOR=
FILTER_END_DATE_SELECTOR=
FILTER_START_TIME_SELECTOR=
FILTER_END_TIME_SELECTOR=
FILTER_OPERATOR_SELECTOR=
FILTER_QUEUE_SELECTOR=
FILTER_STATUS_SELECTOR=
FILTER_SEARCH_BUTTON_SELECTOR=
ROWS_SELECT_SELECTOR=
NEXT_BUTTON_SELECTOR=
JOB_TTL_MINUTES=180

# v11 - relatório verídico obrigatório
# native = usa o botão Excel/CSV do próprio FloraGold depois de aplicar o filtro; é o modo mais fiel ao relatório oficial.
# table = lê apenas a tabela visível na tela; use só para teste.
EXPORT_MODE=native
EXPORT_EXCEL_SELECTOR=
EXPORT_CSV_SELECTOR=

# Proteção v11: o backend não gera telefones/protocolos simulados.
# Se DEMO_MODE=true, /api/relatorios/gerar retorna erro para evitar relatório falso.
