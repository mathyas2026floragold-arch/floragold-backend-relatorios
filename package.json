{
  "name": "backend-render-relatorios",
  "version": "2.1.0",
  "description": "Backend Render para Relatório FloraGold v0.8.5 com RPA Playwright e pausa Ligação 0800 automática.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "install:browsers": "npx playwright install chromium",
    "install:browsers:deps": "npx playwright install --with-deps chromium",
    "postinstall": "npx playwright install chromium"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "playwright": "^1.54.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
